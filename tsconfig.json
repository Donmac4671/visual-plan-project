{
  "compilerOptions": {
    "allowJs": true,

    "noImplicitAny": true,
    "strictNullChecks": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    "strict": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
